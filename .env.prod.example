# =============================================
# ContentForge — PRODUCTION Environment
# cp .env.prod.example .env.prod  then fill in values
# NEVER commit .env.prod to git
# =============================================

# ── App ──────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32

# ── Database (Neon) ───────────────────────────
# Format: postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://USER:PASS@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Redis (local Docker) ──────────────────────
REDIS_URL=redis://redis:6379/0

# ── Server ────────────────────────────────────
# Public server IP or domain, without protocol.
SERVER_IP=YOUR_HETZNER_IP

# ── Self-hosted MinIO ─────────────────────────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# ── Storage (Cloudflare R2) ───────────────────
# Account ID is in the R2 dashboard URL
# In docker-compose.prod.yml the backend talks to MinIO internally, but these
# values are still required by deploy validation and useful for non-Docker runs.
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_MINIO_USER
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET=contentforge-assets
# Public URL for assets.
S3_PUBLIC_DOMAIN=http://YOUR_HETZNER_IP:9000/contentforge-assets
# S3 API endpoint reachable by the browser for presigned uploads.
S3_PRESIGNED_ENDPOINT=http://YOUR_HETZNER_IP:9000

# ── Frontend build vars ───────────────────────
# Set to your Hetzner server IP or domain (no trailing slash, no port)
# Browser API calls go to: http(s)://SERVER_IP/api/*
NEXT_PUBLIC_API_URL=http://YOUR_HETZNER_IP
# Should match S3_PUBLIC_DOMAIN so Next.js allows remote images
NEXT_PUBLIC_STORAGE_DOMAIN=pub-XXXX.r2.dev

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins (same as NEXT_PUBLIC_API_URL)
ALLOWED_ORIGINS=http://YOUR_HETZNER_IP

# ── AI APIs ───────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
ASSEMBLYAI_API_KEY=
TOGETHER_API_KEY=

# ── Online asset import (yt-dlp) ──────────────
YTDLP_COOKIES_FILE=
YTDLP_PROXY=
YTDLP_USER_AGENT=
