# =============================================
# ContentForge Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# =============================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://cf:dev@localhost:5432/contentforge

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Storage (MinIO local dev / Cloudflare R2 prod) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=contentforge-assets
S3_PUBLIC_DOMAIN=http://localhost:9000/contentforge-assets
# Browser-accessible S3 API endpoint used only for presigned upload/download URLs.
# In Docker, keep S3_ENDPOINT internal and set this to the host address.
S3_PRESIGNED_ENDPOINT=http://localhost:9000

# --- AI APIs ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
ASSEMBLYAI_API_KEY=
TOGETHER_API_KEY=

# --- Online asset import (optional) ---
# Only set these if you need authenticated/region-specific downloads.
YTDLP_COOKIES_FILE=
YTDLP_PROXY=
YTDLP_USER_AGENT=

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-in-production
# Optional bootstrap admin. When both are set, the backend creates/updates this
# user on startup and marks it as an active administrator.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Keep ingest usable without AI keys. Enable these only after API keys are configured.
AUTO_AI_TAG_ON_INGEST=false
AUTO_EMBEDDING_ON_INGEST=false

# --- Frontend links ---
# Optional external UGC Outreach app. If empty, ContentForge shows a setup state.
NEXT_PUBLIC_UGC_URL=
# Optional storage domain for Next.js image optimization, without protocol.
NEXT_PUBLIC_STORAGE_DOMAIN=localhost

# SQL statement echo (very verbose; enable only when debugging queries)
SQL_ECHO=false
