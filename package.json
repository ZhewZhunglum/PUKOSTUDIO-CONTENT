{
  "name": "contentforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter contentforge-frontend dev",
    "build": "pnpm --filter contentforge-frontend build",
    "lint": "pnpm --filter contentforge-frontend lint",
    "test": "pnpm --filter contentforge-frontend test",
    "format": "prettier --write \"frontend/**/*.{ts,tsx,json,css,md}\""
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "unrs-resolver"]
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
